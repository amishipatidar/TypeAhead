{
  "name": "search-typeahead",
  "version": "1.0.0",
  "description": "Search Typeahead System with Redis, Consistent Hashing, Batch Writes, and Trending",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node scripts/generateDataset.js && node scripts/loadDataset.js",
    "generate": "node scripts/generateDataset.js",
    "load": "node scripts/loadDataset.js"
  },
  "keywords": ["typeahead", "search", "redis", "consistent-hashing", "HLD"],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2"
  }
}
