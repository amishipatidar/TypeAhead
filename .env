# Server
PORT=3000

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Batch Processing
BATCH_SIZE=5

# Sampling (0.0 to 1.0) — 1.0 means process all, 0.001 means 0.1%
SAMPLE_RATE=1.0

# Decay
DECAY_FACTOR=0.9
DECAY_INTERVAL_SECONDS=60
DECAY_REMOVAL_THRESHOLD=1

# Cache
CACHE_TTL_SECONDS=300
CACHE_NODE_COUNT=3
VIRTUAL_NODES_PER_NODE=150

# Suggestions
TOP_K=10
MIN_PREFIX_LENGTH=1
